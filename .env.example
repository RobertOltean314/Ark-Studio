# FIREBASE CONFIGURATION
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to git!

FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# INSTRUCTIONS:
# 1. Get these values from Firebase Console > Project Settings > General > Your apps
# 2. Replace the placeholder values above
# 3. Save as .env (without .example)
# 4. The .env file will be ignored by git automatically