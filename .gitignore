# client/firestore.rules  
# client/firestore.indexes.json
# client/.firebaserc

# Keep public folder for builds:
# client/public/

# CRITICAL: Only ignore environment files with actual secrets
client/src/environments/environment.ts
client/src/environments/environment.prod.ts
# But keep the example/template files

